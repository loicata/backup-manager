# ═══════════════════════════════════════
# Backup Manager — .gitignore
# ═══════════════════════════════════════

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
*.spec
*.manifest

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
desktop.ini
.DS_Store

# Logs & temp
*.log
crash.log

# Build artifacts
build/dist/
build/src/
build/pyinstaller_build/
*.msi

# App data (user profiles — never commit)
%APPDATA%/BackupManager/
.claude/ 
